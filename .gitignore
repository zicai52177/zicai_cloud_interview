# ================== Maven/Gradle 构建产物 ==================
target/
build/
*.jar
*.war
*.ear
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ================== IDE 配置文件（重点更新！） ==================
# IntelliJ IDEA（直接忽略整个文件夹，最彻底）
.idea/
*.iws
*.iml
*.ipr

# Qoder 文件夹（你要求新增的）
.qoder/

# Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
!**/src/main/**/build/
!**/src/test/**/build/

# VS Code
.vscode/

# ================== 日志文件 ==================
*.log
logs/
log/

# ================== 敏感配置文件（防止泄露密码/密钥） ==================
# 环境变量文件
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging

# 敏感配置文件（包含数据库密码、API密钥等）
application-local.yml
application-local.yaml
application-prod.yml
application-prod.yaml
application-staging.yml
application-staging.yaml
config-local.properties
secrets.properties
credentials.properties
*-secret.yml
*-secret.yaml
*-secret.properties

# ================== 密钥和证书文件（非常重要！） ==================
# 私钥文件
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
*.truststore
id_rsa*
id_ed25519*
*.ppk

# 证书文件（可能包含敏感信息）
*.crt
*.cer
*.der

# SSH 相关
.ssh/
known_hosts
authorized_keys

# GPG 密钥
*.asc
*.gpg
*.gpgr

# ================== 数据库文件（可能包含真实数据） ==================
*.db
*.sqlite
*.sqlite3
*.h2.db
*.mv.db
*.sql.gz
*.sql.zip

# ================== 云服务配置文件 ==================
# AWS
.aws/
credentials

# Azure
.azure/

# GCP
.gcp/
gcloud-credentials.json

# 阿里云/腾讯云
aliyun-credentials.json
tencent-credentials.json

# Kubernetes
.kube/
kubeconfig
*.kubeconfig

# Docker
.docker/
docker-credentials.json

# ================== 其他敏感文件 ==================
# 备份文件（可能包含敏感数据）
*.backup
*.old

# 压缩包（可能包含敏感文件）
*.zip
*.tar.gz
*.rar
*.7z

# ================== 临时文件/备份文件 ==================
*.tmp
*.bak
*.swp
*~
.DS_Store?
Thumbs.db

# ================== 操作系统文件 ==================
# Mac OS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ================== Spring Boot 特有 ==================
spring-configuration-metadata.json
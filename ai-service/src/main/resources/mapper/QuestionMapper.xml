        <result column="difficulty" property="difficulty" />
        <result column="category" property="category" />
        <result column="standard_answer" property="standardAnswer" />
        <result column="key_points" property="keyPoints" />
        <result column="max_score" property="maxScore" />
        <result column="time_limit" property="timeLimit" />
        <result column="user_score" property="userScore" />
        <result column="gmt_create" property="gmtCreate" />
        <result column="gmt_modified" property="gmtModified" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, interview_id, account_id, interview_round_id, status, user_answer, evaluation, content, type, difficulty, category, standard_answer, key_points, max_score, time_limit, user_score, gmt_create, gmt_modified
    </sql>

</mapper>

# ===================================================
# Cloud Interview System - Environment Variables Template
# ===================================================
# Copy this file to each service's src/main/resources/.env
# and fill in the actual values for your environment.
# NEVER commit real credentials to git!
# ===================================================

# ============ Nacos ============
NACOS_SERVER=127.0.0.1:8848
NACOS_USER=nacos
NACOS_PASSWORD=your_nacos_password

# ============ RabbitMQ ============
RABBITMQ_SERVER=127.0.0.1
RABBITMQ_USER=root
RABBITMQ_PASSWORD=your_rabbitmq_password

# ============ MySQL ============
MYSQL_SERVER=127.0.0.1
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password

# ============ Redis ============
REDIS_SERVER=127.0.0.1
REDIS_PASSWORD=your_redis_password

# ============ JWT ============
JWT_SECRET_KEY=your_jwt_secret_key_at_least_64_characters_long_replace_this

# ============ SMS (account-service, product-service) ============
SMS_APP_CODE=your_sms_app_code

# ============ Aliyun OSS ============
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret

# ============ WeChat Login (account-service, product-service) ============
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
WECHAT_TOKEN=your_wechat_token

# ============ WeChat Pay (product-service only) ============
WECHAT_PAY_MCH_ID=your_merchant_id
WECHAT_PAY_CERT_SERIAL_NO=your_cert_serial_no
WECHAT_PAY_API_V3_KEY=your_api_v3_key
WECHAT_PAY_PRIVATE_KEY_PATH=/opt/app/cert/apiclient_key.pem
WECHAT_PAY_PUBLIC_KEY_PATH=/opt/app/cert/pub_key.pem
WECHAT_PAY_PUBLIC_KEY_ID=your_public_key_id
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/v1/order/callback/wechat_pay

# ============ AI Service (ai-service only) ============
ALIBABA_BAILIAN_KEY=your_alibaba_bailian_api_key

# ============ SearXNG (ai-service only) ============
SEARXNG_SERVER=http://127.0.0.1:8081

# ============ MCP Server (ai-service only) ============
MCP_SERVER_URL=http://127.0.0.1:8090

# ============ Internal Service Protection ============
FEIGN_INTERNAL_SECRET=your_internal_service_secret_key
